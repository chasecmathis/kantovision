SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
FRONTEND_URL=http://localhost:3000

# Logging: level is DEBUG/INFO/WARNING/ERROR; set JSON_LOGS=true in production
LOG_LEVEL=INFO
JSON_LOGS=false

# Battle rules
MOVE_TIMEOUT_SECONDS=60
WS_GRACE_PERIOD_SECONDS=30

# Team limits
MAX_TEAMS_PER_USER=10

# CORS — comma-separated list, no spaces
# e.g. https://kantovision.app,https://www.kantovision.app
ALLOWED_ORIGINS=http://localhost:3000

# WebSocket rate limiting (messages per second per connection)
WS_RATE_LIMIT_PER_SECOND=10
